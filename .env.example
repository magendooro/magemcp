# =============================================================================
# MageMCP — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Required — Magento connection
# ---------------------------------------------------------------------------

# Base URL of your Magento 2 / Adobe Commerce instance
MAGENTO_BASE_URL=https://magento.example.com

# Integration token for admin REST API access (grants access to all admin_* tools)
# Create one at: Magento Admin > System > Integrations
MAGEMCP_ADMIN_TOKEN=your-integration-token-here

# ---------------------------------------------------------------------------
# Optional — store and auth
# ---------------------------------------------------------------------------

# Store view code for scoping requests (default: default)
MAGENTO_STORE_CODE=default

# Customer Bearer token for authenticated GraphQL queries
# (only needed for customer-scoped c_* operations)
# MAGENTO_CUSTOMER_TOKEN=

# Legacy alias for MAGEMCP_ADMIN_TOKEN — kept for backward compatibility
# MAGENTO_TOKEN=

# ---------------------------------------------------------------------------
# Optional — server behaviour
# ---------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
MAGEMCP_LOG_LEVEL=INFO

# Set to true to skip confirmation prompts on write/destructive tools
# Useful for automated pipelines; leave unset for interactive use
# MAGEMCP_SKIP_CONFIRMATION=true

# Rate limit — max tool calls per minute (default: 60)
MAGEMCP_RATE_LIMIT=60
